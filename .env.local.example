# ════════════════════════════════════════════════════
#  ONE MORE TRAVEL — Environment Variables
#  Copy this file to .env.local and fill in values.
#  NEVER commit .env.local to git.
# ════════════════════════════════════════════════════

# ── Resend (email service) ───────────────────────────
# 1. Create a free account at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste the key below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FROM address ────────────────────────────────────
# Option A (testing / no domain verification needed):
#   Leave blank — will use onboarding@resend.dev
# Option B (production — recommended):
#   1. In Resend dashboard → Domains → Add Domain
#   2. Add onemoretravel.com
#   3. Add the DNS records Resend shows you
#   4. Once verified, use your desired from address:
RESEND_FROM_EMAIL=omtravel@onemoretravel.com

# ── TO address (where enquiries land) ───────────────
INQUIRY_TO_EMAIL=omtravel@onemoretravel.com

# ════════════════════════════════════════════════════
#  SETUP STEPS
# ════════════════════════════════════════════════════
#
#  LOCAL DEVELOPMENT:
#  1. cp .env.local.example .env.local
#  2. Fill in RESEND_API_KEY
#  3. Set RESEND_FROM_EMAIL=onboarding@resend.dev (no domain needed)
#  4. Set INQUIRY_TO_EMAIL=your-test@email.com
#  5. npm run dev
#  6. Submit the inquiry form → check your email
#
#  PRODUCTION (Vercel):
#  1. In Vercel dashboard → Project → Settings → Environment Variables
#  2. Add RESEND_API_KEY
#  3. Add RESEND_FROM_EMAIL (after domain verification in Resend)
#  4. Add INQUIRY_TO_EMAIL=omtravel@onemoretravel.com
#  5. Redeploy
#
#  DOMAIN VERIFICATION (for custom FROM address):
#  1. resend.com → Domains → Add Domain → onemoretravel.com
#  2. Copy the TXT, MX and DKIM records shown
#  3. Add them in your DNS provider (Cloudflare, Route53, etc.)
#  4. Click Verify in Resend dashboard
#  5. Update RESEND_FROM_EMAIL to use @onemoretravel.com
# ════════════════════════════════════════════════════
